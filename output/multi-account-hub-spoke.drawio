        <mxCell id="conn_fg_kinesis" edge="1" parent="1" source="fargate1" target="kinesis_ds" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8C4FFF;strokeWidth=2;endArrow=open;endSize=4;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#8C4FFF;" value="events&#xa;(via TGW)">
