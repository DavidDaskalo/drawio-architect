        <mxCell id="conn_fg_secrets" edge="1" parent="1" source="fargate1" target="secrets_mgr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#232F3E;strokeWidth=1;endArrow=open;endSize=4;dashed=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#232F3E;" value="credentials">
