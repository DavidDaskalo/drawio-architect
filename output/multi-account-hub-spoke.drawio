        <mxCell id="conn_s3p_athena" edge="1" parent="1" source="s3_processed" target="athena" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#232F3E;strokeWidth=1;endArrow=open;endSize=4;">
